{
  "name": "roboschool-server",
  "version": "2.0.0",
  "description": "RoboSchool CRM Backend — PostgreSQL + JWT + Telegram + SMS",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "build": "npx prisma generate",
    "dev": "nodemon src/app.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset"
},
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1",
    "node-telegram-bot-api": "^0.64.0",
    "axios": "^1.6.2",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.4",
    "compression": "^1.7.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "prisma": "^5.8.0",
    "nodemon": "^3.0.2"
  }
}
