generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
}

enum TimeSlot {
  MORNING
  AFTERNOON
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  EXPELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AchievementType {
  HOMEWORK
  PROJECT
  ACTIVITY
  PARENT_ACTIVITY
  CONTEST_WIN
  GOOD_BEHAVIOR
  ATTENDANCE_STREAK
  PENALTY
  OTHER
}

enum PaymentMethod {
  CASH
  CLICK
  PAYME
  BANK_TRANSFER
}

enum LeadSource {
  INSTAGRAM
  TELEGRAM
  REFERRAL
  WEBSITE
  FACEBOOK
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  TRIAL_SCHEDULED
  TRIAL_DONE
  CONVERTED
  LOST
}

enum ExpenseCategory {
  RENT
  SALARY
  EQUIPMENT
  MARKETING
  UTILITIES
  OTHER
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  fullName     String    @map("full_name")
  phone        String?
  role         UserRole  @default(MANAGER)
  avatar       String?
  isActive     Boolean   @default(true) @map("is_active")
  telegramId   String?   @map("telegram_id")
  refreshToken String?   @map("refresh_token")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Course {
  id          String   @id @default(uuid())
  name        String
  icon        String   @default("📚")
  color       String   @default("#0D9488")
  ageRange    String?  @map("age_range")
  duration    String?
  price          Int      @default(0)
  discountPrice  Int?     @map("discount_price")
  description    String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  groups Group[]

  @@map("courses")
}

model Teacher {
  id             String   @id @default(uuid())
  fullName       String   @map("full_name")
  phone          String?
  email          String?
  specialization String?
  salary         Int      @default(0)
  avatar         String?
  telegramId     String?  @map("telegram_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  groups Group[]

  @@map("teachers")
}

model Group {
  id        String    @id @default(uuid())
  name      String
  courseId   String    @map("course_id")
  teacherId String    @map("teacher_id")
  schedule  String?
  weekDays  String?   @map("week_days")
  timeSlot  TimeSlot  @default(MORNING) @map("time_slot")
  startTime String?   @map("start_time")
  endTime   String?   @map("end_time")
  maxSize   Int       @default(12) @map("max_size")
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  course     Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher    Teacher      @relation(fields: [teacherId], references: [id])
  students   Student[]
  attendance Attendance[]

  @@map("groups")
}

model Student {
  id            String        @id @default(uuid())
  fullName      String        @map("full_name")
  age           Int?
  birthDate     DateTime?     @map("birth_date")
  metrikaNumber String?       @map("metrika_number")
  fatherName    String?       @map("father_name")
  fatherPhone   String?       @map("father_phone")
  motherName    String?       @map("mother_name")
  motherPhone   String?       @map("mother_phone")
  parentPhone   String        @map("parent_phone")
  parentEmail   String?       @map("parent_email")
  address       String?
  groupId       String?       @map("group_id")
  balance       Int           @default(0)
  progress      Int           @default(0)
  totalPoints   Int           @default(0) @map("total_points")
  status        StudentStatus @default(ACTIVE)
  avatar        String?
  telegramId    String?       @map("telegram_id")
  enrollDate    DateTime      @default(now()) @map("enroll_date")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  group        Group?              @relation(fields: [groupId], references: [id], onDelete: SetNull)
  payments     Payment[]
  attendance   Attendance[]
  documents    Document[]
  achievements Achievement[]
  evaluations  StudentEvaluation[]

  @@map("students")
}

model Attendance {
  id        String           @id @default(uuid())
  studentId String           @map("student_id")
  groupId   String           @map("group_id")
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  note      String?
  smsSent   Boolean          @default(false) @map("sms_sent")
  createdAt DateTime         @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([groupId, date])
  @@map("attendance")
}

model Achievement {
  id          String          @id @default(uuid())
  studentId   String          @map("student_id")
  type        AchievementType @default(PROJECT)
  title       String
  description String?
  points      Int             @default(0)
  smsSent     Boolean         @default(false) @map("sms_sent")
  createdAt   DateTime        @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("achievements")
}

enum EvaluationRating {
  POOR
  AVERAGE
  GOOD
  EXCELLENT
}

model StudentEvaluation {
  id             String           @id @default(uuid())
  studentId      String           @map("student_id")
  period         String                                    // "2026-05" format
  teamwork       EvaluationRating @default(AVERAGE)        // Jamoaviy ish
  thinking       EvaluationRating @default(AVERAGE)        // Fikrlash
  behavior       EvaluationRating @default(GOOD)           // Xulq
  mastery        EvaluationRating @default(AVERAGE)        // O'zlashtirish
  creativity     EvaluationRating @default(AVERAGE)        // Kreativ fikrlash
  decisionMaking EvaluationRating @default(AVERAGE) @map("decision_making")  // Tezkor qaror
  independence   EvaluationRating @default(AVERAGE)        // Mustaqillik
  note           String?
  smsSent        Boolean          @default(false) @map("sms_sent")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, period])
  @@index([studentId])
  @@map("student_evaluations")
}

model Payment {
  id            String        @id @default(uuid())
  studentId     String        @map("student_id")
  amount        Int
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  paymentDate   DateTime      @default(now()) @map("payment_date")
  monthFor      String?       @map("month_for")
  note          String?
  receiptUrl    String?       @map("receipt_url")
  createdAt     DateTime      @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([paymentDate])
  @@map("payments")
}

model BotUser {
  id        String   @id @default(uuid())
  chatId    String   @unique @map("chat_id")
  username  String?
  firstName String?  @map("first_name")
  isAdmin   Boolean  @default(false) @map("is_admin")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("bot_users")
}

model Lead {
  id         String     @id @default(uuid())
  fullName   String     @map("full_name")
  phone      String
  source     LeadSource @default(OTHER)
  interest   String?
  status     LeadStatus @default(NEW)
  trialDate  DateTime?  @map("trial_date")
  lossReason String?    @map("loss_reason")
  notes      String?
  assignedTo String?    @map("assigned_to")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@index([status])
  @@index([source])
  @@map("leads")
}

model Expense {
  id          String          @id @default(uuid())
  category    ExpenseCategory
  amount      Int
  description String?
  expenseDate DateTime        @default(now()) @map("expense_date")
  receiptUrl  String?         @map("receipt_url")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([expenseDate])
  @@map("expenses")
}

model Document {
  id        String   @id @default(uuid())
  studentId String?  @map("student_id")
  fileName  String   @map("file_name")
  filePath  String   @map("file_path")
  fileType  String   @map("file_type")
  fileSize  Int      @map("file_size")
  createdAt DateTime @default(now()) @map("created_at")

  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@map("documents")
}

model SmsLog {
  id        String   @id @default(uuid())
  phone     String
  message   String
  status    String   @default("pending")
  provider  String   @default("eskiz")
  errorMsg  String?  @map("error_msg")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sms_logs")
}

model NotificationLog {
  id        String   @id @default(uuid())
  type      String
  recipient String
  message   String
  status    String   @default("sent")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notification_logs")
}